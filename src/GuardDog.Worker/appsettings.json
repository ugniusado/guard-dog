{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "GuardDog": "Information"
    }
  },
  "GuardDog": {
    // ── Database connection ───────────────────────────────────────────────────
    // Production: use Azure Managed Identity (no password in config):
    //   "ConnectionString": "Server=myserver.database.windows.net;Database=MyDb;Authentication=Active Directory Default;"
    // AWS: use IAM role with RDS IAM authentication and no password.
    // NEVER commit credentials here — use environment variables or Key Vault.
    "ConnectionString": "",

    // SqlServer | PostgreSQL
    "Provider": "SqlServer",

    // ── Scheduling ────────────────────────────────────────────────────────────
    "CheckInterval": "00:05:00",

    // ── Alerting ──────────────────────────────────────────────────────────────
    // Minimum severity that triggers an alert: Critical | Warning | Informational
    "AlertThreshold": "Warning",

    "Slack": {
      // Set via environment variable: GuardDog__Slack__WebhookUrl
      "WebhookUrl": "",
      "Channel": "#db-alerts",
      "Username": "Guard Dog"
    },

    "Teams": {
      // Set via environment variable: GuardDog__Teams__WebhookUrl
      "WebhookUrl": ""
    },

    // ── Snapshot (Phase 2 — Shadow Schema) ───────────────────────────────────
    // Path to the snapshot.json generated by GuardDog.SnapshotTool during CI/CD.
    // The worker also checks for an embedded assembly resource named 'snapshot.json'.
    "SnapshotPath": "snapshot.json",

    // ── Mermaid diagram (Phase 4) ─────────────────────────────────────────────
    "GenerateMermaidDiagram": true,
    "MermaidOutputPath": "docs/database.md",

    // ── Prometheus metrics (Phase 5) ──────────────────────────────────────────
    "EnablePrometheusMetrics": true,
    "MetricsPort": 9090
  }
}
